{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F429 (OpenOCD)",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/debug/MYPLAY.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "device": "STM32F429IG",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "runToEntryPoint": "main",
      "preLaunchTask": "build",
      "showDevDebugOutput": "none"
    }
  ]
}

